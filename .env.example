# =============================================
# NIELSON AGRO FERTILIZERS — Environment Config
# =============================================
# Copy this file to .env.local and fill in values

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://nielsonagro.com

# WhatsApp Business Number (with country code, no spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=+1234567890

# ---- Email Integration (pick one) ----
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@nielsonagro.com
SENDGRID_TO_EMAIL=sales@nielsonagro.com

# ---- CRM Integration ----
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=

# ---- Notifications ----
SLACK_WEBHOOK_URL=

# ---- Database / Spreadsheet ----
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# ---- Analytics ----
NEXT_PUBLIC_GTM_ID=GTM-XXXXXX
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ---- Search Console ----
GOOGLE_SITE_VERIFICATION=
